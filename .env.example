# =============================================================
# DocRule — Environment Variables Template
# Copy this to backend/.env and fill in real values.
# NEVER commit the real .env file to Git.
# =============================================================

# Server
PORT=3001
NODE_ENV=production

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=docrule
DB_USER=docrule_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# JWT
# Generate a secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_64_CHAR_RANDOM_HEX_SECRET
JWT_EXPIRES_IN=7d

# CORS — set to your real frontend domain in production
CORS_ORIGIN=https://yourdomain.com

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
SESSION_CLEANUP_INTERVAL_MINUTES=5
MAX_HISTORY_PER_SESSION=10

# File Upload Configuration
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,docx,txt

# Feature Flags
ENABLE_SPELL_CHECK=true
ENABLE_STRUCTURED_FORMATTING=true
ENABLE_EXPORT=true
